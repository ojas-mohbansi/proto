# Agent OS configuration. Copy to .env and edit values you need to override.
# All variables are optional; sensible defaults are used otherwise.

# Path that holds memory/, state/, and logs/ subdirectories.
# Defaults to the project directory.
# AGENT_HOME=/opt/agent-os

# --- LLM provider ---------------------------------------------------------
# "ollama" (self-hosted, default) or "openai" (any OpenAI-compatible endpoint).
LLM_PROVIDER=ollama

# Ollama settings (ignored when LLM_PROVIDER=openai).
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# OpenAI-compatible settings (used when LLM_PROVIDER=openai).
# Works with OpenAI, Together, Groq, OpenRouter, vLLM, llama.cpp server, etc.
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_TIMEOUT=120

# --- API server -----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- Loop / safety --------------------------------------------------------
CHECKPOINT_INTERVAL_SECONDS=300
REPLAN_INTERVAL_SECONDS=86400
HEARTBEAT_STALE_SECONDS=120
WATCHDOG_INTERVAL_SECONDS=30
MAX_MEMORY_MB=4096
EPISODIC_RETENTION_DAYS=90

# --- WhatsApp bot ---------------------------------------------------------
# Full international number WITHOUT the plus sign, suffixed with @s.whatsapp.net
# Example: 919876543210@s.whatsapp.net
WA_OWNER_NUMBER=
WA_BOT_NAME=Proto
WA_OWNER_NAME=Owner
WA_PREFIX=!
WA_PUBLIC_MODE=false
# Paste a base64 session string here to skip the QR pairing flow on first start.
WA_SESSION_ID=
# Backend URL the bot calls.
AGENT_API_BASE=http://localhost:8000
